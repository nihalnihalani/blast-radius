REDIS_URL=redis://localhost:6379
WEAVE_PROJECT=blast-radius
# Leave WANDB_API_KEY unset (or set WEAVE_DISABLED=1) to run without W&B tracing.
# WANDB_API_KEY=...
WEAVE_DISABLED=1
AGENT_NAME=infra_orchestrator
# Circuit-breaker tuning
BREAKER_THRESHOLD=5
BREAKER_WINDOW_SECONDS=10
BREAKER_OPEN_TTL_SECONDS=10
DLQ_REDELIVERY_THRESHOLD=3
# Demo pacing so the DAG + breaker trip are visible on stage (set 0 to disable)
DEMO_STEP_DELAY=0.45
DEMO_BREAKER_HOLD=2.5
