REDIS_URL=redis://localhost:6379
CHECKPOINTER=redis                # redis (durable) | memory
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AGENT_NAME=infra_orchestrator
# Weave (optional): set WANDB_API_KEY and remove WEAVE_DISABLED to enable tracing
WEAVE_PROJECT=blast-radius
WEAVE_DISABLED=1
# WANDB_API_KEY=...
# OpenAI (optional): set to make the validator use GPT for risk assessment
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
# Circuit-breaker tuning
BREAKER_THRESHOLD=5
BREAKER_WINDOW_SECONDS=10
BREAKER_OPEN_TTL_SECONDS=10
DLQ_REDELIVERY_THRESHOLD=3
# Demo pacing (0 disables)
DEMO_STEP_DELAY=0.45
DEMO_BREAKER_HOLD=2.5
